# Database
DATABASE_URL="postgresql://c2farms:c2farms_dev@localhost:5432/c2farms"

# Auth
JWT_SECRET="change-me-to-a-random-secret"

# Server
PORT=3001
NODE_ENV=development

# CORS (comma-separated origins, required in production)
# CORS_ORIGIN="https://c2farms.onrender.com"

# Frontend URL (for email links, etc.)
# FRONTEND_URL="https://c2farms.onrender.com"

# Claude AI (settlement PDF extraction, AI reconciliation)
# ANTHROPIC_API_KEY=""

# QuickBooks Online (OAuth integration — optional)
QB_CLIENT_ID=""
QB_CLIENT_SECRET=""
QB_REDIRECT_URI="http://localhost:3001/api/quickbooks/callback"
QB_ENVIRONMENT="sandbox"

# Token encryption key (AES-256-GCM, required if using QB/FieldOps tokens)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# QB_TOKEN_ENCRYPTION_KEY=""

# AWS S3 (mobile ticket photo uploads — optional)
# AWS_ACCESS_KEY_ID=""
