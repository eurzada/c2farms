generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password_hash String
  name          String
  role          String         @default("farm_manager")
  modules       Json           @default("[\"forecast\",\"inventory\",\"marketing\",\"logistics\",\"agronomy\",\"enterprise\"]")
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  farm_roles     UserFarmRole[]
  audit_logs     AuditLog[]
  activity_logs  ActivityLog[]

  @@map("users")
}

model Farm {
  id              String           @id @default(uuid())
  name            String
  is_enterprise   Boolean          @default(false)
  farm_type       String           @default("farm") // farm | terminal
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  user_roles      UserFarmRole[]
  audit_logs      AuditLog[]
  agro_plans      AgroPlan[]
  agro_products   AgroProduct[]
  season_profiles SeasonProfile[]
  labour_plans              LabourPlan[]
  cwo_field_group_mappings  CwoFieldGroupMapping[]

  terminal_bins              TerminalBin[]
  terminal_tickets           TerminalTicket[]
  terminal_blend_events      TerminalBlendEvent[]
  terminal_contracts         TerminalContract[]
  terminal_settlements       TerminalSettlement[]
  daily_positions            DailyPosition[]

  @@map("farms")
}

model UserFarmRole {
  id      String @id @default(uuid())
  user_id String
  farm_id String
  role    String @default("admin")
  modules Json   @default("[\"forecast\",\"inventory\",\"marketing\",\"logistics\",\"agronomy\",\"enterprise\"]") // which modules this user can access
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  farm    Farm   @relation(fields: [farm_id], references: [id], onDelete: Cascade)

  @@unique([user_id, farm_id])
  @@map("user_farm_roles")
}

model Assumption {
  id           String    @id @default(uuid())
  farm_id      String
  fiscal_year  Int
  start_month  String    @default("Nov")
  end_month    String    @default("Oct")
  total_acres  Float
  crops_json   Json      @default("[]")
  bins_json    Json      @default("[]")
  is_frozen    Boolean   @default(false)
  frozen_at    DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@unique([farm_id, fiscal_year])
  @@map("assumptions")
}

model MonthlyData {
  id            String   @id @default(uuid())
  farm_id       String
  fiscal_year   Int
  month         String
  type          String   // 'per_unit' or 'accounting'
  data_json     Json     @default("{}")
  is_actual     Boolean  @default(false)
  comments_json Json     @default("{}")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@unique([farm_id, fiscal_year, month, type])
  @@index([farm_id, fiscal_year])
  @@map("monthly_data")
}

model MonthlyDataFrozen {
  id            String   @id @default(uuid())
  farm_id       String
  fiscal_year   Int
  month         String
  type          String
  data_json     Json     @default("{}")
  is_actual     Boolean  @default(false)
  comments_json Json     @default("{}")
  created_at    DateTime @default(now())

  @@unique([farm_id, fiscal_year, month, type])
  @@index([farm_id, fiscal_year])
  @@map("monthly_data_frozen")
}

model FinancialCategory {
  id            Int     @id
  code          String  @unique
  display_name  String
  parent_id     Int?
  path          String
  level         Int
  sort_order    Int
  category_type String
  parent        FinancialCategory?  @relation("CategoryParent", fields: [parent_id], references: [id])
  children      FinancialCategory[] @relation("CategoryParent")

  @@map("financial_categories")
}

model QbCategoryMapping {
  id              String @id @default(uuid())
  farm_id         String
  qb_account_name String
  category_code   String
  weight          Float  @default(1.0)

  @@unique([farm_id, qb_account_name])
  @@map("qb_category_mappings")
}

model QbToken {
  id            String   @id @default(uuid())
  farm_id       String   @unique
  access_token  String
  refresh_token String
  realm_id      String
  expires_at    DateTime

  @@map("qb_tokens")
}

model FieldOpsToken {
  id            String   @id @default(uuid())
  farm_id       String   @unique
  access_token  String
  refresh_token String
  expires_at    DateTime
  connected_at  DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("fieldops_tokens")
}

model FarmCategory {
  id            String         @id @default(uuid())
  farm_id       String
  code          String
  display_name  String
  parent_id     String?
  path          String
  level         Int
  sort_order    Int
  category_type String         // REVENUE, INPUT, LPM, LBF, INSURANCE
  is_active     Boolean        @default(true)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt

  parent        FarmCategory?  @relation("FarmCategoryParent", fields: [parent_id], references: [id])
  children      FarmCategory[] @relation("FarmCategoryParent")
  gl_accounts   GlAccount[]

  @@unique([farm_id, code])
  @@map("farm_categories")
}

model GlAccount {
  id             String          @id @default(uuid())
  farm_id        String
  account_number String
  account_name   String
  category_id    String?
  qb_account_id  String?
  is_active      Boolean         @default(true)
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt

  category       FarmCategory?   @relation(fields: [category_id], references: [id])
  actuals        GlActualDetail[]

  @@unique([farm_id, account_number])
  @@map("gl_accounts")
}

model GlActualDetail {
  id            String    @id @default(uuid())
  farm_id       String
  fiscal_year   Int
  month         String
  gl_account_id String
  amount        Float
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  gl_account    GlAccount @relation(fields: [gl_account_id], references: [id])

  @@unique([farm_id, fiscal_year, month, gl_account_id])
  @@map("gl_actual_details")
}

model FarmInvite {
  id         String   @id @default(uuid())
  farm_id    String
  email      String
  role       String   @default("viewer")
  invited_by String
  status     String   @default("pending") // pending, accepted, expired
  created_at DateTime @default(now())
  expires_at DateTime

  @@unique([farm_id, email])
  @@map("farm_invites")
}

model OperationalData {
  id           String   @id @default(uuid())
  farm_id      String
  fiscal_year  Int
  month        String
  metric       String   // 'labour_hours', 'equipment_hours', 'fuel_litres'
  budget_value Float    @default(0)
  actual_value Float    @default(0)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([farm_id, fiscal_year, month, metric])
  @@map("operational_data")
}

model AiConversation {
  id         String      @id @default(uuid())
  farm_id    String
  user_id    String
  title      String?
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt
  messages   AiMessage[]

  @@index([farm_id])
  @@map("ai_conversations")
}

model AiMessage {
  id              String         @id @default(uuid())
  conversation_id String
  role            String         // user, assistant, system
  content         String
  context_json    Json?
  metadata_json   Json?
  created_at      DateTime       @default(now())
  conversation    AiConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id])
  @@map("ai_messages")
}

// ─── Inventory Module (Grain Control Centre) ────────────────────────

model Commodity {
  id         String          @id @default(uuid())
  farm_id    String
  name       String
  code       String
  lbs_per_bu Float
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt
  bins                InventoryBin[]
  bin_counts          BinCount[]
  contracts           Contract[]
  marketing_contracts MarketingContract[]
  market_prices       MarketPrice[]
  price_alerts        PriceAlert[]
  delivery_tickets        DeliveryTicket[]
  terminal_bins           TerminalBin[]
  terminal_contracts      TerminalContract[]
  terminal_settlement_lines TerminalSettlementLine[]
  aliases CommodityAlias[]
  withdrawals InventoryWithdrawal[]
  elevator_tickets ElevatorTicket[]

  @@unique([farm_id, code])
  @@map("commodities")
}

model CommodityAlias {
  id           String    @id @default(uuid())
  farm_id      String
  commodity_id String
  alias        String    // e.g. "Yellow Peas" from CSV
  source       String    @default("import") // import, manual
  created_at   DateTime  @default(now())
  commodity    Commodity @relation(fields: [commodity_id], references: [id], onDelete: Cascade)

  @@unique([farm_id, alias])
  @@map("commodity_aliases")
}

model InventoryLocation {
  id          String            @id @default(uuid())
  farm_id     String
  name        String
  code        String
  cluster     String            @default("individual") // central, individual, transit
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
  bins        InventoryBin[]
  submissions CountSubmission[]
  delivery_tickets DeliveryTicket[]

  @@unique([farm_id, code])
  @@map("inventory_locations")
}

model InventoryBin {
  id          String            @id @default(uuid())
  farm_id     String
  location_id String
  bin_number  String
  bin_type    String            @default("hopper") // hopper, flat, temporary
  capacity_bu Float?
  commodity_id String?
  notes       String?
  purpose     String            @default("market") // market, seed, feed, reserved, consumption
  is_active   Boolean           @default(true)
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
  location    InventoryLocation @relation(fields: [location_id], references: [id], onDelete: Cascade)
  commodity   Commodity?        @relation(fields: [commodity_id], references: [id])
  bin_counts  BinCount[]
  delivery_tickets DeliveryTicket[]
  withdrawals InventoryWithdrawal[]

  @@unique([farm_id, location_id, bin_number])
  @@map("inventory_bins")
  bin_grades      BinGrade[]
}

model InventoryWithdrawal {
  id              String    @id @default(uuid())
  farm_id         String
  bin_id          String
  commodity_id    String?
  bushels         Float
  kg              Float
  reason          String    // seed, feed, loss, consumption, transfer
  withdrawal_date DateTime  @db.Date
  notes           String?
  created_by      String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  bin             InventoryBin @relation(fields: [bin_id], references: [id])
  commodity       Commodity?   @relation(fields: [commodity_id], references: [id])

  @@index([farm_id, bin_id])
  @@index([farm_id, withdrawal_date])
  @@map("inventory_withdrawals")
}

model BinGrade {
  id              String            @id @default(uuid())
  farm_id         String
  bin_id          String
  crop_year       Int
  grade           String            // e.g. "Wheat, No.1 CWRS"
  grade_short     String?           // e.g. "1 CWRS" — display-friendly
  variety         String?           // e.g. "CWRS", "Nexera", "Eston", "Kabuli"
  grade_reason    String?           // e.g. "HVK", "FROST", "Colour"
  protein_pct     Float?
  moisture_pct    Float?
  dockage_pct     Float?
  test_weight     Float?            // g/0.5L
  hvk_pct         Float?
  frost           String?           // e.g. "1-M"
  colour          String?           // e.g. "1" or "Satisfactory"
  falling_number  Float?            // Falling Number (FN seconds)
  fusarium_pct    Float?            // FUS %
  bushels         Float?            // reported bushels from grading sheet
  origin          String?           // e.g. "CAN" — grain origin
  quality_json    Json?             // all remaining quality metrics as key-value pairs
  inspector_notes String?
  source          String            @default("efu") // efu, manual, grain_index
  grade_date      DateTime?         @db.Date
  status          String            @default("available") // available, shipped, emptied
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  bin             InventoryBin      @relation(fields: [bin_id], references: [id], onDelete: Cascade)

  @@unique([farm_id, bin_id, crop_year])
  @@index([farm_id, crop_year])
  @@map("bin_grades")
}

model CountPeriod {
  id          String            @id @default(uuid())
  farm_id     String
  period_date DateTime          @db.Date
  crop_year   Int
  status      String            @default("open") // open, closed
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
  bin_counts       BinCount[]
  submissions      CountSubmission[]
  elevator_tickets ElevatorTicket[]

  @@unique([farm_id, period_date])
  @@map("count_periods")
}

model CountSubmission {
  id              String            @id @default(uuid())
  farm_id         String
  count_period_id String
  location_id     String
  submitted_by    String?
  status          String            @default("draft") // draft, submitted, approved, rejected
  notes           String?
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  count_period    CountPeriod       @relation(fields: [count_period_id], references: [id], onDelete: Cascade)
  location        InventoryLocation @relation(fields: [location_id], references: [id], onDelete: Cascade)

  @@unique([farm_id, count_period_id, location_id])
  @@map("count_submissions")
}

model BinCount {
  id              String       @id @default(uuid())
  farm_id         String
  count_period_id String
  bin_id          String
  commodity_id    String?
  bushels         Float        @default(0)
  kg              Float        @default(0)
  crop_year       Int?
  notes           String?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  count_period    CountPeriod  @relation(fields: [count_period_id], references: [id], onDelete: Cascade)
  bin             InventoryBin @relation(fields: [bin_id], references: [id], onDelete: Cascade)
  commodity       Commodity?   @relation(fields: [commodity_id], references: [id])

  @@unique([farm_id, count_period_id, bin_id])
  @@map("bin_counts")
}

model Contract {
  id             String     @id @default(uuid())
  farm_id        String
  contract_number String?
  buyer          String
  commodity_id   String
  contracted_mt  Float
  price_per_mt   Float?
  status         String     @default("open") // open, fulfilled, cancelled
  notes          String?
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt
  commodity      Commodity  @relation(fields: [commodity_id], references: [id])
  deliveries     Delivery[]

  @@map("contracts")
}

model Delivery {
  id                    String              @id @default(uuid())
  farm_id               String
  contract_id           String?
  marketing_contract_id String?
  mt_delivered          Float
  gross_weight_mt       Float?
  dockage_pct           Float?
  delivery_date         DateTime            @db.Date
  ticket_number         String?
  notes                 String?
  created_at            DateTime            @default(now())
  updated_at            DateTime            @updatedAt
  contract              Contract?           @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  marketing_contract    MarketingContract?  @relation(fields: [marketing_contract_id], references: [id])

  @@map("deliveries")
}

// ─── Grain Marketing Module ──────────────────────────────────────────

model Counterparty {
  id                  String              @id @default(uuid())
  farm_id             String
  name                String
  short_code          String
  type                String              @default("buyer") // buyer, broker, elevator, terminal
  contact_name        String?
  contact_email       String?
  contact_phone       String?
  default_elevator_site String?
  is_active           Boolean             @default(true)
  notes               String?
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
  marketing_contracts   MarketingContract[]
  delivery_tickets      DeliveryTicket[]
  settlements           Settlement[]
  terminal_tickets      TerminalTicket[]
  terminal_contracts    TerminalContract[]
  terminal_settlements  TerminalSettlement[]
  aliases CounterpartyAlias[]
  elevator_tickets ElevatorTicket[]
  procurement_contracts ProcurementContract[]

  @@unique([farm_id, name])
  @@map("counterparties")
}

model CounterpartyAlias {
  id              String       @id @default(uuid())
  farm_id         String
  counterparty_id String
  alias           String       // e.g. "G3 Canada" from CSV
  source          String       @default("import") // import, manual
  created_at      DateTime     @default(now())
  counterparty    Counterparty @relation(fields: [counterparty_id], references: [id], onDelete: Cascade)

  @@unique([farm_id, alias])
  @@map("counterparty_aliases")
}

model MarketingContract {
  id                        String        @id @default(uuid())
  farm_id                   String
  contract_number           String
  contract_type             String        @default("third_party") // third_party | transfer (LGX inter-company blending agreement)
  linked_terminal_contract_id String?     // LGX sale to JGL etc.; only for contract_type=transfer
  crop_year                 String        // e.g. "2025/26"
  commodity_id              String
  counterparty_id           String
  grade                     String?
  broker                    String?
  contracted_mt             Float
  contracted_bu             Float?        // for transfer: blend recipe component (both bu and mt available)
  delivered_mt              Float         @default(0)
  remaining_mt              Float
  tolerance_pct             Float?
  pricing_type              String        @default("flat") // flat, basis, hta, min_price, deferred
  pricing_status            String        @default("priced") // priced, unpriced, partially_priced
  price_per_bu              Float?
  price_per_mt              Float?
  basis_level               Float?        // $/bu
  futures_reference         String?       // e.g. "ICE RS May26"
  futures_price             Float?        // $/bu for HTA
  currency                  String        @default("CAD")
  delivery_start            DateTime?     @db.Date
  delivery_end              DateTime?     @db.Date
  elevator_site             String?
  farm_origin               String?
  status                    String        @default("executed") // executed, in_delivery, delivered, settled, cancelled
  settlement_date           DateTime?     @db.Date
  settlement_amount         Float?
  contract_value            Float?
  cop_per_mt                Float?
  notes                     String?
  contract_document_url     String?      // S3 URL for uploaded contract PDF
  grade_prices_json         Json?        // for transfer: [{ grade: "Durum #1", price_per_mt: 288 }, ...]
  blend_requirement_json    Json?        // for transfer: [{ grade: "Durum #1", mt: 800 }, ...]
  blend_mix_updated_at      DateTime?
  created_by                String?
  created_at                DateTime      @default(now())
  updated_at                DateTime      @updatedAt
  counterparty              Counterparty    @relation(fields: [counterparty_id], references: [id])
  commodity                 Commodity       @relation(fields: [commodity_id], references: [id])
  linked_terminal_contract  TerminalContract? @relation(fields: [linked_terminal_contract_id], references: [id])
  deliveries                Delivery[]
  cash_flow_entries         CashFlowEntry[]
  delivery_tickets          DeliveryTicket[]
  settlements               Settlement[]

  @@unique([farm_id, contract_number])
  @@index([farm_id, commodity_id])
  @@index([farm_id, status])
  @@index([farm_id, contract_type])
  @@index([linked_terminal_contract_id])
  @@map("marketing_contracts")
}

model MarketPrice {
  id               String    @id @default(uuid())
  farm_id          String
  commodity_id     String
  price_date       DateTime  @db.Date
  bid_per_bu       Float?
  basis_per_bu     Float?
  futures_reference String?
  futures_close    Float?
  buyer_name       String?
  outlook          String?   // sideways, bullish, bearish
  cop_per_bu       Float?
  target_price_bu  Float?
  notes            String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  commodity        Commodity @relation(fields: [commodity_id], references: [id])

  @@unique([farm_id, commodity_id, price_date])
  @@map("market_prices")
}

model PriceAlert {
  id              String    @id @default(uuid())
  farm_id         String
  commodity_id    String
  alert_type      String    // target_price, basis_trigger, percent_change
  direction       String    // above, below
  threshold_value Float
  is_active       Boolean   @default(true)
  triggered_at    DateTime?
  triggered_value Float?
  notify_method   String?   @default("in_app")
  created_by      String?
  notes           String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  commodity       Commodity @relation(fields: [commodity_id], references: [id])

  @@index([farm_id, commodity_id, is_active])
  @@map("price_alerts")
}

model CashFlowEntry {
  id                    String             @id @default(uuid())
  farm_id               String
  period_date           DateTime           @db.Date
  entry_type            String             // requirement, receipt
  category              String             // fertilizer, seed, chemical, loc_interest, overhead, equipment, land_rent, grain_sale, other
  description           String?
  amount                Float              // positive = inflow, negative = outflow
  marketing_contract_id String?
  is_actual             Boolean            @default(false)
  notes                 String?
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt
  marketing_contract    MarketingContract? @relation(fields: [marketing_contract_id], references: [id])

  @@index([farm_id, period_date, entry_type])
  @@map("cash_flow_entries")
}

model MarketingSettings {
  id                      String   @id @default(uuid())
  farm_id                 String   @unique
  loc_interest_rate       Float    @default(0.0725)
  storage_cost_per_mt_month Float  @default(3.5)
  default_currency        String   @default("CAD")
  contract_prefix         String   @default("MKT")
  next_contract_seq       Int      @default(1)
  next_counterparty_seq   Int      @default(1)
  loc_available           Float?
  fiscal_year_start_month Int      @default(11)
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  @@map("marketing_settings")
}

// ─── Grain Logistics (Tickets, Settlements, Reconciliation) ─────────

model DeliveryTicket {
  id                    String             @id @default(uuid())
  farm_id               String
  marketing_contract_id String?
  counterparty_id       String?
  commodity_id          String?
  bin_id                String?
  location_id           String?
  ticket_number         String             // Traction Ag ticket #
  delivery_date         DateTime           @db.Date
  gross_weight_kg       Float?
  tare_weight_kg        Float?
  net_weight_kg         Float
  net_weight_mt         Float              // computed: net_weight_kg / 1000
  tare_weight_mt        Float?             // computed: tare_weight_kg / 1000
  dockage_pct           Float?
  moisture_pct          Float?
  grade                 String?
  protein_pct           Float?
  source_system         String             @default("traction_ag") // traction_ag, manual
  source_ref            String?            // Load ID from Traction Ag
  source_ticket_number  String?            // buyer's ticket # if known
  source_timestamp      DateTime?          // original Traction Ag timestamp (full date+time)
  operator_name         String?
  vehicle               String?
  destination           String?
  crop_year             Int?
  bin_label             String?            // raw bin/bag identifier from CSV (e.g. "508 Bag 1")
  contract_number       String?            // raw contract # from CSV (e.g. "55040499")
  buyer_name            String?            // raw buyer name from CSV (e.g. "Richardson")
  settled               Boolean            @default(false)
  notes                 String?
  photo_url             String?            // S3 full-size image URL
  photo_thumbnail_url   String?            // S3 300px thumbnail URL
  extraction_json       Json?              // raw Claude Vision output (audit trail)
  extraction_confidence Float?             // 0-1 confidence score
  submitted_by          String?            // user ID of trucker who submitted
  mobile_submitted_at   DateTime?          // device timestamp from mobile app
  client_id             String?            // UUID for offline idempotency
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt
  marketing_contract    MarketingContract? @relation(fields: [marketing_contract_id], references: [id])
  counterparty          Counterparty?      @relation(fields: [counterparty_id], references: [id])
  commodity             Commodity?         @relation(fields: [commodity_id], references: [id])
  bin                   InventoryBin?      @relation(fields: [bin_id], references: [id])
  location                  InventoryLocation? @relation(fields: [location_id], references: [id])
  settlement_lines          SettlementLine[]

  @@unique([farm_id, client_id])
  @@index([farm_id, ticket_number])
  @@index([farm_id, delivery_date])
  @@index([farm_id, marketing_contract_id])
  @@map("delivery_tickets")
}

model Settlement {
  id                    String             @id @default(uuid())
  farm_id               String
  counterparty_id       String?
  marketing_contract_id String?
  ai_batch_id           String?            // links to AiBatch for batch-processed extractions
  batch_custom_id       String?            // custom_id within the Anthropic batch
  extraction_status     String             @default("completed") // completed, queued, processing, failed
  settlement_number     String
  settlement_date       DateTime?          @db.Date
  total_amount          Float?
  settlement_gross      Float?             // total gross before deductions
  deductions_summary    Json?              // [{name, amount, gst, pst, category}]
  currency              String             @default("CAD")
  status                String             @default("pending") // pending, reconciled, disputed, approved
  buyer_format          String?            // cargill, bunge, jgl, unknown
  source                String             @default("pdf_upload")
  terminal_settlement_id String?
  source_pdf_url        String?
  extraction_json       Json?              // raw Claude extraction output for audit
  usage_json            Json?              // AI token usage and cost tracking
  notes                 String?
  exported_at           DateTime?          // when settlement was exported to QB
  reconciliation_report Json?
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt
  counterparty          Counterparty?      @relation(fields: [counterparty_id], references: [id])
  marketing_contract    MarketingContract? @relation(fields: [marketing_contract_id], references: [id])
  ai_batch              AiBatch?           @relation(fields: [ai_batch_id], references: [id])
  lines                 SettlementLine[]

  @@unique([farm_id, settlement_number])
  @@index([farm_id, status])
  @@index([ai_batch_id])
  @@map("settlements")
}

model AiBatch {
  id                  String       @id @default(uuid())
  farm_id             String
  anthropic_batch_id  String?      // Anthropic's batch ID (msgbatch_...)
  status              String       @default("queued") // queued, processing, completed, failed, expired
  total_requests      Int          @default(0)
  completed_count     Int          @default(0)
  failed_count        Int          @default(0)
  total_input_tokens  Int          @default(0)
  total_output_tokens Int          @default(0)
  estimated_cost_usd  Float        @default(0)
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt
  completed_at        DateTime?
  error_message       String?
  settlements         Settlement[]

  @@index([farm_id, status])
  @@index([anthropic_batch_id])
  @@map("ai_batches")
}

model SettlementLine {
  id                         String          @id @default(uuid())
  settlement_id              String
  delivery_ticket_id         String?         // matched ticket
  line_number                Int
  ticket_number_on_settlement String?        // buyer's ticket #
  contract_number            String?         // per-line contract # (multi-contract settlements)
  delivery_date              DateTime?       @db.Date
  commodity                  String?
  grade                      String?
  gross_weight_mt            Float?
  net_weight_mt              Float?
  price_per_mt               Float?
  price_per_bu               Float?
  deductions_json            Json?           // [{name, amount}]
  line_gross                 Float?
  line_net                   Float?
  match_status               String          @default("unmatched") // unmatched, matched, exception, manual
  match_confidence           Float?          // 0-1
  exception_reason           String?
  created_at                 DateTime        @default(now())
  updated_at                 DateTime        @updatedAt
  settlement                 Settlement      @relation(fields: [settlement_id], references: [id], onDelete: Cascade)
  delivery_ticket            DeliveryTicket? @relation(fields: [delivery_ticket_id], references: [id])

  @@index([settlement_id])
  @@map("settlement_lines")
}

model SettlementFormatHint {
  id            String   @id @default(uuid())
  farm_id       String
  buyer_format  String   // g3, cargill, bunge, jgl, richardson, gsl, ldc, unknown
  hint_text     String   // admin's correction instruction
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  created_by    String?

  @@index([farm_id, buyer_format])
  @@map("settlement_format_hints")
}

model AgroPlan {
  id          String           @id @default(uuid())
  farm_id     String
  crop_year   Int
  status          String           @default("draft") // draft, submitted, approved, locked, rejected
  prepared_by     String?
  submitted_by    String?          // email of user who submitted (for rejection notification)
  approved_by     String?
  approved_at     DateTime?
  rejected_by     String?
  rejected_at     DateTime?
  rejection_notes String?
  notes           String?
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt

  farm        Farm             @relation(fields: [farm_id], references: [id])
  allocations CropAllocation[]

  @@unique([farm_id, crop_year])
  @@map("agro_plans")
}

model CropAllocation {
  id              String      @id @default(uuid())
  plan_id         String
  crop            String
  acres           Float
  target_yield_bu Float
  commodity_price Float
  sort_order      Int         @default(0)
  n_rate_per_bu   Float?
  p_rate_per_bu   Float?
  k_rate_per_bu   Float?
  s_rate_per_bu   Float?
  available_n     Float?
  cu_target       Float?      // Cu target lbs/acre (flat, agronomist-set)
  b_target        Float?      // B target lbs/acre (flat, agronomist-set)
  zn_target       Float?      // Zn target lbs/acre (flat, agronomist-set)

  plan            AgroPlan    @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  inputs          CropInput[]

  @@unique([plan_id, crop])
  @@map("crop_allocations")
}

model CropInput {
  id               String         @id @default(uuid())
  allocation_id    String
  category         String         // seed, seed_treatment, fertilizer, chemical
  product_name     String
  product_analysis String?        // "82-0-0", "11-52-0", "12-40-0-10-1"
  form             String?        // dry, liquid, nh3, micro_nutrient, granular
  timing           String?        // fall_residual, preburn, incrop, fungicide, desiccation
  rate             Float
  rate_unit        String         // lbs/acre, L/acre, US Gal/Acre, per acre
  cost_per_unit    Float
  acres            Float?         // varietal-specific acres (seed/seed_treatment); null = use allocation.acres
  sort_order       Int            @default(0)

  allocation       CropAllocation @relation(fields: [allocation_id], references: [id], onDelete: Cascade)

  @@map("crop_inputs")
}

model AgroProduct {
  id                      String  @id @default(uuid())
  farm_id                 String
  name                    String
  type                    String  // seed, fertilizer, chemical, adjuvant
  sub_type                String? // herbicide, fungicide, insecticide, growth_reg
  crop_filter             String? // comma-separated crops or null for all
  analysis_code           String? // "46-0-0" (fertilizers)
  form                    String? // dry, liquid, nh3, micro_nutrient
  default_unit            String?
  default_rate            Float?
  default_cost            Float?
  // Dealer pricing fields (from Work Order import)
  unit_price              Float?  // $/packaging unit from dealer
  packaging_unit          String? // MB, DRUM, JUG, TOTE, etc.
  packaging_volume        Float?  // volume/weight per package in base units (L or kg)
  dealer_code             String? // Synergy product code
  dealer_name             String? // e.g. "LAKELAND"
  canonical_name          String? // normalized name for fuzzy matching
  cost_per_application_unit Float? // computed $/L or $/lb for merging with CropInput rates
  timing_tags             String? // comma-separated: "preburn,incrop", "fungicide", "seeding"

  farm          Farm @relation(fields: [farm_id], references: [id])

  @@unique([farm_id, name, type])
  @@map("agro_products")
}

model SeasonProfile {
  id        String @id @default(uuid())
  farm_id   String
  crop      String
  crop_year Int
  apr_pct   Float  @default(0)
  may_pct   Float  @default(0)
  jun_pct   Float  @default(0)
  jul_pct   Float  @default(0)
  aug_pct   Float  @default(0)
  sep_pct   Float  @default(0)
  oct_pct   Float  @default(0)

  farm      Farm @relation(fields: [farm_id], references: [id])

  @@unique([farm_id, crop, crop_year])
  @@map("season_profiles")
}

// ─── Work Orders & CWO Import ───────────────────────────────────────

model WorkOrderLine {
  id               String   @id @default(uuid())
  farm_id          String
  customer_name    String
  work_order_ref   String
  order_date       DateTime?
  payment_due_date DateTime?
  product_name     String
  product_code     String?
  packaging_unit   String?
  qty_ordered      Float    @default(0)
  qty_taken        Float    @default(0)
  qty_remaining    Float    @default(0)
  prepaid          Float    @default(0)
  unit_price       Float    @default(0)
  line_total       Float    @default(0)
  crop_year        Int
  canonical_name   String?
  created_at       DateTime @default(now())

  @@map("work_order_lines")
}

// ─── Procurement Contracts ──────────────────────────────────────────

model ProcurementContract {
  id                String   @id @default(uuid())
  farm_id           String   // Enterprise farm ID
  contract_number   String   // Supplier's contract # (e.g., "20556173")
  counterparty_id   String
  crop_year         Int
  input_category    String   // fertilizer, fuel, chemical, seed
  description       String?
  blend_formula     String?  // Custom NPK blend e.g. "32-21-24"
  contract_value    Float?   // Total CAD across all lines
  currency          String   @default("CAD")
  valid_from        DateTime? @db.Date
  valid_to          DateTime? @db.Date
  payment_due       String?  // May be a date or text like "On delivery"
  delivery_window   String?  // "Apr-May 2026", "Spring 2026"
  status            String   @default("ordered") // ordered, in_transit, delivered, invoiced, paid, cancelled
  source_file       String?
  notes             String?
  created_by        String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  counterparty      Counterparty @relation(fields: [counterparty_id], references: [id])
  lines             ProcurementContractLine[]

  @@unique([farm_id, contract_number])
  @@index([farm_id, status])
  @@index([farm_id, crop_year])
  @@map("procurement_contracts")
}

model ProcurementContractLine {
  id                String   @id @default(uuid())
  contract_id       String
  line_number       Int
  bu_farm_id        String?  // FK to BU farm (e.g., Lewvan)
  input_category    String   // fertilizer, fuel, chemical, seed
  product_code      String?  // Supplier product code
  product_name      String
  product_analysis  String?  // NPK: "46-0-0"
  blend_formula     String?  // Blend this line belongs to: "32-21-24"
  qty               Float    @default(0)
  qty_unit          String   @default("tonnes") // tonnes, litres, lbs, kg
  unit_price        Float    @default(0)
  price_unit        String   @default("$/tonne") // $/tonne, ¢/L, $/lb
  line_total        Float    @default(0) // qty * unit_price
  delivered_qty     Float    @default(0)
  notes             String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  contract          ProcurementContract @relation(fields: [contract_id], references: [id], onDelete: Cascade)

  @@index([contract_id])
  @@map("procurement_contract_lines")
}

model CwoFieldGroupMapping {
  id          String @id @default(uuid())
  farm_id     String
  field_group String
  crop_year   Int

  farm        Farm @relation(fields: [farm_id], references: [id])

  @@unique([field_group, crop_year])
  @@map("cwo_field_group_mappings")
}

model CwoImportSnapshot {
  id           String   @id @default(uuid())
  crop_year    Int
  label        String   // "Spring 2026 Plan", "Mid-Season Update"
  source       String   @default("cwo_export")
  imported_by  String?
  row_count    Int      @default(0)
  summary_json Json?
  created_at   DateTime @default(now())

  @@map("cwo_import_snapshots")
}

// ─── Labour Planning ─────────────────────────────────────────────────

model LabourPlan {
  id          String   @id @default(uuid())
  farm_id     String
  fiscal_year Int
  status      String   @default("draft") // draft | approved | locked
  avg_wage    Decimal  @default(0)
  total_acres Int      @default(0)
  notes       String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  farm    Farm           @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  seasons LabourSeason[]

  @@unique([farm_id, fiscal_year])
  @@map("labour_plans")
}

model LabourSeason {
  id         String   @id @default(uuid())
  plan_id    String
  name       String
  sort_order Int
  months     String[] // fiscal months, e.g. ["May"] or ["Jun","Jul","Aug"]
  created_at DateTime @default(now())

  plan  LabourPlan  @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  roles LabourRole[]

  @@unique([plan_id, name])
  @@map("labour_seasons")
}

model LabourRole {
  id         String   @id @default(uuid())
  season_id  String
  name       String
  hours      Decimal  @default(0)
  sort_order Int
  created_at DateTime @default(now())

  season LabourSeason @relation(fields: [season_id], references: [id], onDelete: Cascade)

  @@unique([season_id, name])
  @@map("labour_roles")
}

// ─── Audit Trail ─────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  farm_id     String
  user_id     String
  entity_type String
  entity_id   String
  action      String
  changes     Json?
  metadata    Json?
  created_at  DateTime @default(now())

  farm Farm @relation(fields: [farm_id], references: [id])
  user User @relation(fields: [user_id], references: [id])

  @@index([farm_id, entity_type, entity_id])
  @@index([farm_id, created_at])
  @@map("audit_logs")
}

model ActivityLog {
  id         String   @id @default(uuid())
  user_id    String
  action     String   // login, login_failed, page_view, data_edit, import, export
  detail     String?  // e.g. "PATCH /api/farms/.../per-unit/2026/Apr"
  ip_address String?
  user_agent String?
  metadata   Json?
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id, created_at])
  @@index([created_at])
  @@index([ip_address])
  @@map("activity_logs")
}

// ─── Terminal Operations (LGX) ──────────────────────────────────────

model TerminalBin {
  id                    String    @id @default(uuid())
  farm_id               String
  bin_number            Int
  name                  String
  current_commodity_id  String?
  current_product_label String?
  balance_kg            Float     @default(0)
  c2_balance_kg         Float     @default(0)
  non_c2_balance_kg     Float     @default(0)
  capacity_kg           Float?
  is_active             Boolean   @default(true)
  swept_clean_at        DateTime?
  notes                 String?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  farm      Farm           @relation(fields: [farm_id], references: [id])
  commodity Commodity?     @relation(fields: [current_commodity_id], references: [id])
  tickets   TerminalTicket[]
  blend_events_as_source TerminalBlendEvent[] @relation("BlendSource")
  blend_events_as_blend  TerminalBlendEvent[] @relation("BlendTarget")
  daily_positions        DailyPosition[]

  @@unique([farm_id, bin_number])
  @@map("terminal_bins")
}

model TerminalTicket {
  id              String    @id @default(uuid())
  farm_id         String
  bin_id          String?
  ticket_number   Int
  direction       String    // inbound | outbound
  ticket_date     DateTime

  grower_name     String?
  grower_id       String?
  product         String
  weight_kg       Float
  fmo_number      String?
  buyer           String?

  dockage_pct     Float?
  moisture_pct    Float?
  test_weight     Float?
  protein_pct     Float?
  hvk_pct         Float?

  rail_car_number String?
  vehicle_id      String?
  sold_to         String?
  seal_numbers    String?
  outbound_kg     Float?

  is_c2_farms     Boolean   @default(false)
  balance_after_kg Float?
  contract_id     String?           // assigned sale contract

  status          String    @default("complete") // complete | voided
  scale_source    String    @default("manual")   // manual | scale_api
  notes           String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  farm     Farm              @relation(fields: [farm_id], references: [id])
  bin      TerminalBin?      @relation(fields: [bin_id], references: [id])
  grower   Counterparty?     @relation(fields: [grower_id], references: [id])
  contract TerminalContract? @relation(fields: [contract_id], references: [id])
  samples TerminalSample[]
  terminal_settlement_lines TerminalSettlementLine[]

  @@unique([farm_id, ticket_number])
  @@index([farm_id, direction])
  @@index([farm_id, ticket_date])
  @@index([farm_id, grower_name])
  @@map("terminal_tickets")
}

model TerminalBlendEvent {
  id              String    @id @default(uuid())
  farm_id         String
  blend_date      DateTime
  description     String
  outbound_buyer  String

  source_bin_id   String
  source_bin_pct  Float
  blend_bin_id    String
  blend_bin_pct   Float

  total_output_kg Float
  source_bin_kg   Float
  blend_bin_kg    Float
  rail_car_numbers String[]
  car_count       Int
  target_protein  Float?
  notes           String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  farm       Farm        @relation(fields: [farm_id], references: [id])
  source_bin TerminalBin @relation("BlendSource", fields: [source_bin_id], references: [id])
  blend_bin  TerminalBin @relation("BlendTarget", fields: [blend_bin_id], references: [id])

  @@index([farm_id, blend_date])
  @@map("terminal_blend_events")
}

model TerminalSample {
  id              String    @id @default(uuid())
  ticket_id       String
  inspector       String
  sample_type     String    // onsite | shipped | lit_graded
  send_date       DateTime?
  tracking_number String?
  notes           String?
  created_at      DateTime  @default(now())

  ticket TerminalTicket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  @@map("terminal_samples")
}

model TerminalContract {
  id              String    @id @default(uuid())
  farm_id         String
  contract_number String
  direction       String    // purchase | sale
  counterparty_id String
  commodity_id    String
  contracted_mt   Float
  delivered_mt    Float     @default(0)
  remaining_mt    Float
  price_per_mt    Float?
  ship_mode       String?   // truck | rail
  delivery_point  String?
  start_date      DateTime?
  end_date        DateTime?
  status          String    @default("executed") // executed | in_delivery | fulfilled | settled | cancelled
  notes           String?
  grade_prices_json    Json?
  blend_requirement_json Json?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  farm               Farm                @relation(fields: [farm_id], references: [id])
  counterparty       Counterparty        @relation(fields: [counterparty_id], references: [id])
  commodity          Commodity           @relation(fields: [commodity_id], references: [id])
  settlements        TerminalSettlement[]
  transfer_agreements MarketingContract[]
  assigned_tickets   TerminalTicket[]

  @@unique([farm_id, contract_number])
  @@index([farm_id, direction])
  @@map("terminal_contracts")
}

model TerminalSettlement {
  id                    String    @id @default(uuid())
  farm_id               String
  settlement_number     String
  type                  String    @default("transfer") // transfer | transloading | buyer_settlement
  counterparty_id       String
  contract_id           String?
  marketing_contract_id String?
  settlement_date       DateTime
  gross_amount          Float     @default(0)
  deductions            Json?
  net_amount            Float     @default(0)
  status                String    @default("draft") // draft | finalized | pushed
  pushed_settlement_id  String?
  paired_transfer_id    String?   // links buyer settlement → paired transfer settlement(s)
  realization_json      Json?     // { transfer_net, buyer_net, margin, margin_per_mt, margin_pct }
  settlement_gross      Float?    // gross before deductions (from PDF extraction)
  deductions_summary    Json?     // [{ name, amount, gst, pst, category }] from PDF
  extraction_json       Json?     // raw Claude Vision extraction result
  extraction_status     String?   // pending | completed | failed
  buyer_format          String?   // jgl | cargill | richardson | etc.
  notes                 String?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  farm         Farm              @relation(fields: [farm_id], references: [id])
  counterparty Counterparty      @relation(fields: [counterparty_id], references: [id])
  contract     TerminalContract? @relation(fields: [contract_id], references: [id])
  lines        TerminalSettlementLine[]

  @@unique([farm_id, settlement_number])
  @@map("terminal_settlements")
}

model TerminalSettlementLine {
  id                      String   @id @default(uuid())
  terminal_settlement_id  String
  line_number             Int
  ticket_id               String?
  source_farm_name        String?
  commodity_id            String?
  grade                   String?
  gross_weight_mt         Float?
  tare_weight_mt          Float?
  net_weight_mt           Float?
  price_per_mt            Float?
  line_amount             Float?
  match_status            String?  @default("unmatched") // matched | unmatched | exception | manual
  match_confidence        Float?
  created_at              DateTime @default(now())

  terminal_settlement  TerminalSettlement @relation(fields: [terminal_settlement_id], references: [id], onDelete: Cascade)
  ticket               TerminalTicket?    @relation(fields: [ticket_id], references: [id])
  commodity            Commodity?         @relation(fields: [commodity_id], references: [id])

  @@index([terminal_settlement_id])
  @@map("terminal_settlement_lines")
}

model DailyPosition {
  id            String   @id @default(uuid())
  farm_id       String
  position_date DateTime
  bin_id        String
  commodity     String
  balance_kg    Float
  c2_kg         Float    @default(0)
  non_c2_kg     Float    @default(0)
  computed_at   DateTime @default(now())

  farm Farm        @relation(fields: [farm_id], references: [id])
  bin  TerminalBin @relation(fields: [bin_id], references: [id])

  @@unique([farm_id, position_date, bin_id])
  @@index([farm_id, position_date])
  @@map("daily_positions")
}

// ─── Elevator Ticket Import (Buyer Portal Data for Recon) ────────────

model ElevatorTicket {
  id                String       @id @default(uuid())
  farm_id           String
  count_period_id   String
  counterparty_id   String?
  commodity_id      String?
  ticket_number     String
  delivery_date     DateTime?    @db.Date
  commodity_raw     String?      // raw commodity name from portal file
  buyer_name        String?      // raw buyer name from portal file
  net_weight_mt     Float
  gross_weight_mt   Float?
  tare_weight_mt    Float?
  grade             String?
  protein_pct       Float?
  moisture_pct      Float?
  dockage_pct       Float?
  contract_number   String?
  destination       String?
  source_system     String       @default("portal_csv") // portal_csv, portal_excel
  source_file       String?      // original filename
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt
  count_period      CountPeriod  @relation(fields: [count_period_id], references: [id], onDelete: Cascade)
  counterparty      Counterparty? @relation(fields: [counterparty_id], references: [id])
  commodity         Commodity?   @relation(fields: [commodity_id], references: [id])

  @@unique([farm_id, count_period_id, ticket_number])
  @@index([farm_id, count_period_id])
  @@index([farm_id, delivery_date])
  @@map("elevator_tickets")
}
