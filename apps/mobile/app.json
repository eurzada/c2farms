{
  "expo": {
    "name": "C2 Farms",
    "slug": "c2farms-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B5E20"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.c2farms.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "C2 Farms needs camera access to photograph delivery tickets."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B5E20"
      },
      "package": "com.c2farms.mobile",
      "permissions": [
        "CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "C2 Farms needs camera access to photograph delivery tickets."
        }
      ],
      "expo-asset",
      "expo-secure-store"
    ]
  }
}
